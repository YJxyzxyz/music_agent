# ============================================================
# 音乐 Agent 配置模板 —— 复制为 .env 后填写你自己的值
# ============================================================

# ---------- DeepSeek（生成朋友圈配文）----------
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- PushPlus（推送到微信）----------
# 关注『PushPlus推送加』公众号，在 https://www.pushplus.plus 拿到 token
PUSHPLUS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- 运行参数 ----------
# 每天定时运行时间（24 小时制，本地时区）
RUN_TIME=09:00
# 每次挑选的歌曲数量
N_SONGS=5
# 额外抓取的推荐歌单数（用于扩充候选歌池）
N_PLAYLISTS=3
# 近期推荐去重天数；设为 0 可关闭
RECENT_DEDUP_DAYS=30
# 新口味探索占比，0 到 1，默认每 5 首中保留 1 首探索位
EXPLORE_RATIO=0.2
# 配文场景：default / morning / commute / focus / night / weekend
SCENE_MODE=default
# 每周音乐报告；日期使用英文星期，默认周日 20:00 生成并推送
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_DAY=sunday
WEEKLY_REPORT_TIME=20:00
WEEKLY_REPORT_PUSH=true
# 外部接口重试总次数、指数退避基数（秒）和单次超时（秒）
API_RETRY_ATTEMPTS=3
API_RETRY_BACKOFF=1.5
API_TIMEOUT=20
